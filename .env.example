# Sample environment configuration
# Copy to .env and replace all CHANGE_ME values
# Generate secrets: openssl rand -base64 32

# Database
POSTGRES_USER=busapp
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=bustickets
POSTGRES_PORT=5432
DATABASE_URL=postgresql://busapp:CHANGE_ME@db:5432/bustickets
POSTGRES_HOST_PORT=5433

# Bind service names
DB_HOST=db

# FastAPI
BACKEND_PORT=8000

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=https://admin.maximovtours.com,https://maximovtours.com,https://www.maximovtours.com

# Front-end
FRONTEND_PORT=3000
APP_PUBLIC_URL=https://maximovtours.com
CLIENT_APP_BASE=https://maximovtours.com
# Base URL for admin client-side API calls (same-origin)
PUBLIC_API_BASE=/api

# LiqPay
LIQPAY_PUBLIC_KEY=CHANGE_ME
LIQPAY_PRIVATE_KEY=CHANGE_ME
LIQPAY_CURRENCY=UAH

# Admin credentials for /auth/login
ADMIN_USERNAME=CHANGE_ME
ADMIN_PASSWORD=CHANGE_ME
# Token returned on successful login
ADMIN_TOKEN=CHANGE_ME

# Secret key used to sign tokens
JWT_SECRET=CHANGE_ME
TICKET_LINK_SECRET=CHANGE_ME
TICKET_LINK_TTL_DAYS=3

# SMTP settings
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=Bus Tickets

# CheckBox (Ukrainian PRRO fiscalization)
CHECKBOX_ENABLED=false
CHECKBOX_API_URL=https://api.checkbox.ua
CHECKBOX_ACCESS_KEY=
CHECKBOX_LICENSE_KEY=
CHECKBOX_CASHIER_LOGIN=
CHECKBOX_CASHIER_PASSWORD=
